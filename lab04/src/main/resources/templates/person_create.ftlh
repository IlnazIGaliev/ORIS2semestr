<!DOCTYPE html>
<html lang="ru">
<head>
    <title>Create Person</title>
</head>
<body>

<h2>Create Person</h2>

<form action="/persons" method="post">

    Name:
    <input type="text" name="name"/>

    <br><br>

    Phone:
    <input type="text" name="phoneNumber"/>

    <br><br>

    <button type="submit">Save</button>

</form>

</body>
</html>